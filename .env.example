DATABASE_URL=postgresql://agent:agent@localhost:5432/agentflow
# auto | postgres | memory  (无 Postgres 时用 auto 可正常启动)
CHECKPOINTER=auto
# off = V1 linear graph; llm = LLM planner routes rag vs chat
SUPERVISOR_MODE=off
# sequential = supervisor handoff; parallel = Send fan-out subtasks
DISPATCH_MODE=sequential
SUMMARY_TOKEN_THRESHOLD=4000
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini
# DeepSeek example:
# DEFAULT_LLM_PROVIDER=deepseek
# DEFAULT_MODEL=deepseek-chat
# Langfuse observability (optional — leave disabled if not using)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Frontend (fe/.env or shell)
# Dev: leave unset — Vite proxies /v1 → http://localhost:8000
# NUXT_PUBLIC_API_BASE=http://localhost:8000
# NUXT_PUBLIC_DEFAULT_FLOW_ID=rag-flow

# Multi-tenant (Plan 07)
TENANT_MODE=false
JWT_SECRET=
ADMIN_API_KEY=

# Rate limiting: requests per minute per tenant (0 = disabled)
RATE_LIMIT_RPM=60

# RAG backend: RAGFlow HTTP API (documents managed in RAGFlow UI)
RAG_BACKEND=ragflow
# Remote RAGFlow on a 16GB+ Linux VM (recommended):
# RAGFLOW_BASE_URL=http://<server-ip>
# Local dev only (16GB+ machine):
# RAGFLOW_BASE_URL=http://localhost
RAGFLOW_BASE_URL=http://localhost
RAGFLOW_API_KEY=
RAGFLOW_TOP_K=5
# Comma-separated dataset IDs from RAGFlow UI (used when chat omits dataset_ids)
RAGFLOW_DEFAULT_DATASET_IDS=

# When using RAGFlow, set flow to rag-flow in DebugToolbar or via:
# NUXT_PUBLIC_DEFAULT_FLOW_ID=rag-flow

# Web search via self-hosted SearXNG (./scripts/setup-searxng.sh)
WEB_SEARCH_ENABLED=false
SEARXNG_BASE_URL=http://localhost:8080
# Server compose: SEARXNG_BASE_URL=http://searxng:8080 (set in docker-compose.server.yml)
WEB_SEARCH_TOP_K=5
# llm = structured LLM intent (default); heuristic = keyword rules only
WEB_SEARCH_INTENT_MODE=llm

# export OLLAMA_ORIGINS="http://localhost:3000"
