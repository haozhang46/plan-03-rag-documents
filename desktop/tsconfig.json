{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "types": ["node"]
  },
  "include": ["electron/**/*", "src/**/*", "shared/**/*", "tests/**/*"]
}
