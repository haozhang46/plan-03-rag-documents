# Copy to ragflow-external-deps.env and fill in values.
#   cp scripts/ragflow-external-deps.env.example scripts/ragflow-external-deps.env
# setup-ragflow-server.sh loads this file automatically.
#
# Leave MYSQL_HOST / REDIS_HOST empty to use bundled Docker containers.

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=ragflow
MYSQL_PASSWORD=
MYSQL_DBNAME=rag_flow

REDIS_HOST=
REDIS_PASSWORD=
# REDIS_USERNAME=
