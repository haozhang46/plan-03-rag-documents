# Dev: leave NUXT_PUBLIC_API_BASE unset — Vite proxies /v1 → http://localhost:8000
# Do NOT set to /v1 (composables already append /v1/... → would become /v1/v1/chat)
# NUXT_PUBLIC_API_BASE=http://localhost:8000
#
# Remote API (frontend only, no local backend):
#   cp .env.localServer.example .env.localServer
#   pnpm dev:localServer
# Or: ./scripts/dev-fe-local-server.sh

# When RAG_BACKEND=ragflow on the API, default to rag-flow in DebugToolbar:
NUXT_PUBLIC_DEFAULT_FLOW_ID=rag-flow
